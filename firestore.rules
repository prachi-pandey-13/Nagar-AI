rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == "prachipandey24975@gmail.com";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Issue Entity Validation Helper
    function isValidIssue(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.imageUrl is string && data.imageUrl.size() <= 600000
        && data.category is string && data.category.size() <= 50
        && (data.severity == "low" || data.severity == "medium" || data.severity == "high")
        && data.department is string && data.department.size() <= 100
        && (data.status == "Reported" || data.status == "In Review" || data.status == "Resolved")
        && data.latitude is number
        && data.longitude is number
        && data.upvotesCount is int
        && (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.size() <= 15000000))
        && (
          // Signed-in reporter check
          (isVerified() && data.reporterId == request.auth.uid && data.reporterEmail == request.auth.token.email && data.reporterName is string && data.reporterName.size() <= 100)
          ||
          // Anonymous reporter check
          (data.reporterName == "Anonymous Citizen" && (data.reporterEmail == "" || data.reporterEmail == "anonymous@nagarai.app") && data.reporterId.startsWith("anon_"))
        )
        && (!('isAnonymous' in data) || data.isAnonymous is bool);
    }

    // Reporter Entity Validation Helper
    function isValidReporter(data) {
      return data.uid is string
        && data.name is string && data.name.size() <= 100
        && data.issueCount is int
        && (
          (isVerified() && data.uid == request.auth.uid && data.email == request.auth.token.email && data.photoURL is string && data.photoURL.size() <= 1000)
          ||
          (data.uid.startsWith("anon_") && data.name == "Anonymous Citizen" && (data.email == "" || data.email == "anonymous@nagarai.app") && data.photoURL == "")
        )
        && (!('isAnonymous' in data) || data.isAnonymous is bool);
    }

    // Issues Collection Rules
    match /issues/{issueId} {
      allow read: if true;
      
      allow create: if (isVerified() || (incoming().reporterName == "Anonymous Citizen" && (incoming().reporterEmail == "" || incoming().reporterEmail == "anonymous@nagarai.app") && incoming().reporterId.startsWith("anon_")))
        && isValidId(issueId) 
        && issueId == incoming().id
        && isValidIssue(incoming())
        && incoming().status == "Reported"
        && incoming().upvotesCount == 0
        && incoming().createdAt == request.time;

      allow update: if (isVerified() || isAdmin())
        && isValidIssue(incoming())
        && incoming().id == existing().id
        && incoming().reporterId == existing().reporterId
        && incoming().createdAt == existing().createdAt
        && (
          // Case 1: Admin updating status (Reported -> In Review -> Resolved)
          (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
          
          // Case 2: Standard user upvoting
          (incoming().diff(existing()).affectedKeys().hasOnly(['upvotesCount']) 
           && (incoming().upvotesCount == existing().upvotesCount + 1 || incoming().upvotesCount == existing().upvotesCount - 1))
        );
        
      allow delete: if isAdmin();

      // Upvotes Subcollection Rules
      match /upvotes/{userId} {
        allow read: if isVerified();
        allow create: if isVerified() 
          && userId == request.auth.uid
          && incoming().voterId == request.auth.uid
          && incoming().createdAt == request.time;
        allow delete: if isVerified() 
          && userId == request.auth.uid;
      }
    }

    // Reporters Collection Rules
    match /reporters/{userId} {
      allow read: if true;
      
      allow create: if (isVerified() || (userId.startsWith("anon_") && incoming().name == "Anonymous Citizen" && (incoming().email == "" || incoming().email == "anonymous@nagarai.app") && incoming().photoURL == ""))
        && userId == incoming().uid
        && isValidReporter(incoming())
        && incoming().issueCount == 1;

      allow update: if isVerified()
        && userId == request.auth.uid
        && isValidReporter(incoming())
        && (
          incoming().issueCount == existing().issueCount + 1 ||
          incoming().issueCount == existing().issueCount ||
          incoming().name != existing().name ||
          incoming().photoURL != existing().photoURL
        );
    }
  }
}
